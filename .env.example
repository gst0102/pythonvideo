# 数据库账号密钥
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=postgres
DB_PORT=5432
DB_NAME=video

# 小程序账号密钥（请替换为真实值）
APPID=your_appid_here
SECRET=your_secret_here

# 微信云开发环境
evn=cloud1-0gnyce4y6d0e6caa

# 微信支付商户号
mchid=your_mchid_here
serial_no=your_serial_no_here
APIv3=your_apiv3_key_here
WECHATPAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHATPAY_public_key_path=./certs/apiclient_cert.pem

# 服务器IP和端口
IP=0.0.0.0
PORT=8000

# 身份认证jwt
SECRET_KEY=change_this_to_a_secure_random_key
ALGORITHM=HS256
TOKEN_EXPIRE=7200

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379

# 其他API密钥（可选）
API_KEY=
APPCODE=
ZHIPU_API_KEY=
DEEP_SEEK_API_KEY=
QQ_MAP_KEY=
TENCENT_APPID=
TENCENT_SECRETID=
TENCENT_SECRETKEY=

# 数据库连接（langgraph）
DB_URI=postgresql://postgres:your_password_here@postgres:5432/agent?sslmode=disable
