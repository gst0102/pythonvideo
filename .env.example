# ============================================================
#  视频下载助手 —— 环境变量模板
#  复制此文件为 .env 并填入真实值
#  命令: cp .env.example .env
# ============================================================

# ==================== 微信小程序 ====================
# 小程序 AppID（微信公众平台 → 开发 → 开发管理 → 开发设置）
APPID=your_appid_here

# 小程序 AppSecret（微信公众平台 → 开发 → 开发管理 → 开发设置）
SECRET=your_secret_here

# 微信云开发环境 ID
evn=cloud1-0gnyce4y6d0e6caa

# ==================== 微信支付 ====================
mchid=your_mchid_here
serial_no=your_serial_no_here
APIv3=your_apiv3_key_here
NOTIFY_URL=https://api.lifelove.top/wxpay/api/pay/notify
WECHATPAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHATPAY_public_key_path=./certs/apiclient_cert.pem

# ==================== 服务器配置 ====================
DOMAIN=api.lifelove.top
IP=0.0.0.0
PORT=8000

# CORS 跨域（生产环境填具体域名，逗号分隔）
CORS_ORIGINS=https://api.lifelove.top,https://www.lifelove.top

# ==================== JWT 身份认证 ====================
SECRET_KEY=change_this_to_a_secure_random_key
ALGORITHM=HS256
TOKEN_EXPIRE=7200

# ==================== Redis 配置 ====================
# 本地开发用 127.0.0.1，Docker 部署用 redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PASSWORD=

# ==================== VIP 会员配置 ====================
# 测试模式：月卡 0.1 元（生产环境改 false + 改价格）
VIP_TEST_MODE=true
VIP_MONTHLY_PRICE=0.1
VIP_QUARTERLY_PRICE=26.90
VIP_YEARLY_PRICE=88.80

# ==================== 番剧数据同步配置 ====================
# 本地开发用 http://127.0.0.1:8000，生产部署用 https://api.lifelove.top
ANIME_SOURCE_URL=http://127.0.0.1:8000/anime/resources
# 同步间隔（分钟），默认 15
ANIME_SYNC_INTERVAL=15

# ==================== 其他 API 密钥（可选） ====================
API_KEY=
APPCODE=
ZHIPU_API_KEY=
DEEP_SEEK_API_KEY=
QQ_MAP_KEY=
TENCENT_APPID=
TENCENT_SECRETID=
TENCENT_SECRETKEY=

# ==================== 视频下载配置 ====================
COOKIE_FILE=cookies.txt
PROXY_URL=

# ============================================================
#  企业微信应用配置（自建应用）—— 需申请
#  管理后台: https://work.weixin.qq.com/wework_admin/loginpage
# ============================================================

# 企业 ID —— 企业微信管理后台 → 我的企业 → 企业信息
WECOM_CORP_ID=

# 应用 AgentID —— 应用管理 → 自建应用 → 应用详情
WECOM_AGENT_ID=

# 应用 Secret —— 应用管理 → 自建应用 → 应用详情 → 点击查看
WECOM_SECRET=

# 回调 URL 验证 Token（自定义 3-32 位随机字符串）
WECOM_TOKEN=

# 回调消息 EncodingAESKey（43 位随机字符串，可在后台随机生成）
WECOM_ENCODING_AES_KEY=

# 企业微信消息回调地址（需要 HTTPS 公网可访问）
WECOM_CALLBACK_URL=

# 小程序页面路径（企业微信卡片跳转目标，通常无需修改）
WECOM_MINIPROGRAM_PAGE=pages/wecom/download

# 视频下载存储目录（相对于后端项目根目录）
WECOM_DOWNLOADS_DIR=downloads

# access_token 缓存 Key（Redis 中使用的 key 名）
WECOM_TOKEN_CACHE_KEY=wecom:access_token

# access_token 提前刷新时间（秒），默认在过期前 5 分钟刷新
WECOM_TOKEN_REFRESH_AHEAD=300

# 企业微信 API 端点（通常无需修改）
WECOM_API_GET_TOKEN=https://qyapi.weixin.qq.com/cgi-bin/gettoken
WECOM_API_SEND_MESSAGE=https://qyapi.weixin.qq.com/cgi-bin/message/send
WECOM_API_USER_INFO=https://qyapi.weixin.qq.com/cgi-bin/user/get
